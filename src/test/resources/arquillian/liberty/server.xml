<server description="arquillian">
    <featureManager>
        <feature>faces-4.1</feature>
        <feature>expressionLanguage-6.0</feature>
        <feature>servlet-6.1</feature>
        <feature>cdi-4.1</feature>
        <feature>websocket-2.2</feature>
        <feature>validation-3.1</feature>
        <feature>jsonp-2.1</feature> <!-- Not for OmniFaces itself, but for ScriptParamIT test case -->
        <!-- NOTE: jakartaee-11.0 is not yet available in 26.0.0.1-beta; once available, all of above can be replaced with a single jakartaee-11.0 feature -->
        <feature>localConnector-1.0</feature>
    </featureManager>
    <applicationMonitor updateTrigger="mbean" />
    <httpEndpoint id="defaultHttpEndpoint" httpPort="8080" httpsPort="8443" />
    <applicationManager autoExpand="true" />
</server>